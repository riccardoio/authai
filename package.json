{
  "name": "authai",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "pnpm -r --parallel --filter './apps/*' dev",
    "dev:relay": "pnpm --filter @authai-io/relay-server dev",
    "dev:demo": "pnpm --filter demo-react dev",
    "dev:demo:nextjs": "pnpm --filter demo-nextjs dev",
    "dev:demo:backend": "pnpm --filter demo-backend dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "release": "pnpm -r --filter '@authai-io/*' --filter 'authai-cloud' publish --access public --no-git-checks"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
