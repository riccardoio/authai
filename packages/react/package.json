{
  "name": "@authai-io/react",
  "version": "0.2.1",
  "description": "AuthAI React SDK — <SignIn>, <AuthAIProvider>, useAuthAI(). Sign in with ChatGPT / Grok / Copilot.",
  "homepage": "https://authai.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/authai-io/authai.git",
    "directory": "packages/react"
  },
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepack": "pnpm build && node ../../scripts/prepack.mjs",
    "postpack": "node ../../scripts/postpack.mjs"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "jsdom": "^25.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
